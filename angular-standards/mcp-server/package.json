{
  "name": "angular-standards-mcp",
  "version": "0.1.1",
  "description": "MCP server for Angular architecture standards — Cursor, GitHub Copilot, Claude Desktop, and Claude Code.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "angular-standards-mcp": "./dist/index.js",
    "angular-standards-setup": "./scripts/setup.mjs"
  },
  "files": [
    "dist",
    "standards",
    "templates",
    "scripts/setup.mjs",
    "scripts/copy-standards.mjs"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-standards.mjs",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Himakar-tit/ai-coding-standards.git",
    "directory": "angular-standards/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/Himakar-tit/ai-coding-standards/issues"
  },
  "homepage": "https://github.com/Himakar-tit/ai-coding-standards#readme",
  "keywords": [
    "mcp",
    "angular",
    "cursor",
    "copilot",
    "claude",
    "github-copilot",
    "claude-code",
    "architecture",
    "code-review",
    "model-context-protocol"
  ]
}
